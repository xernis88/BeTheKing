.vs/

# OS
.DS_Store
Thumbs.db

# Packages — include manifest, exclude cache
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json
/[Pp]ackages/*/*
!/[Pp]ackages/*/package.json
!/[Pp]ackages/*/[Ee]ditor/

# Asset Store tools
[Aa]ssets/AssetStoreTools*

# TextMesh Pro
[Aa]ssets/TextMesh*

